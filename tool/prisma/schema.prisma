generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String
  role        UserRole     @default(MANAGER)
  avatarUrl   String?
  isBlocked   Boolean      @default(false)
  blockedAt   DateTime?
  blockedBy   String?
  createdAt   DateTime     @default(now())
  lastLoginAt DateTime?
  engagements Engagement[]
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

model Account {
  id             String       @id @default(cuid())
  canonicalName  String       @unique
  aliases        String[]     @default([])
  industry       Industry     @default(OTHER)
  region         Region?
  accountTier    AccountTier?
  primaryContact String?
  contactEmail   String?
  crmExternalId  String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  engagements    Engagement[]
}

enum Industry {
  HEALTHCARE
  FINTECH
  EDUCATION
  GOVERNMENT
  MEDIA
  ECOMMERCE
  NONPROFIT
  MANUFACTURING
  PROFESSIONAL_SERVICES
  TECHNOLOGY
  ENERGY
  LEGAL
  OTHER
}

enum Region {
  NA
  EMEA
  APAC
  LATAM
}

enum AccountTier {
  ENTERPRISE
  MID_MARKET
  SMB
}

model Engagement {
  id                     String                   @id @default(cuid())
  clientName             String
  projectName            String?
  techStack              TechStack
  engagementType         EngagementType           @default(NEW_BUILD)
  status                 EngagementStatus         @default(DRAFT)
  workflowPath           WorkflowPath?
  templateFileUrl        String?
  templateStatus         Json? // { questionsRfp?: boolean, salesDetail?: boolean, backend?: boolean, frontend?: boolean, fixedCost?: boolean, ai?: boolean }
  // Account link
  account                Account?                 @relation(fields: [accountId], references: [id])
  accountId              String?
  // Business metadata
  rfpSource              RfpSource?
  estimatedDealValue     Float?
  dealCurrency           String?                  @default("USD")
  submissionDeadline     DateTime?
  submittedAt            DateTime?
  presalesOwner          String?
  salesOwner             String?
  isCompetitiveBid       Boolean?                 @default(true)
  numberOfCompetitors    Int?
  presalesHoursSpent     Float?
  tags                   String[]                 @default([])
  // Import provenance
  importSource           String? // "ZIP_IMPORT" | null
  importFilePath         String? // original folder name from ZIP
  importedAt             DateTime?
  financialProposalValue Float? // actual amount from financial proposal
  estimatedBudget        Float? // tentative budget mentioned in TOR
  deliveryTimeline       String? // e.g. "6 months", "Q3 2026"
  rfpIssuedAt            DateTime? // when the RFP was issued
  // Free-text scope augmentation
  techStackCustom        String? // free-text when techStack=OTHER or when augmenting a canonical stack
  techStackIsCustom      Boolean                  @default(false) // true when user chose OTHER; triggers tech-stack research
  projectDescription     String? // user-provided description of what the project is about (1-3 paragraphs)
  legacyPlatform         String? // MIGRATION/REDESIGN: free-text description of current platform
  legacyPlatformUrl      String? // MIGRATION/REDESIGN: current site URL if any
  techStackResearch      TechStackResearch?
  // Outcome tracking (recorded via admin back-office)
  outcome                EngagementOutcome?
  lossReason             LossReason?
  lossReasonDetail       String?
  winFactors             String[]                 @default([])
  competitorWhoWon       String?
  actualContractValue    Float?
  outcomeFeedback        String?
  outcomeRecordedAt      DateTime?
  outcomeRecordedBy      String?
  estimationMode         EstimationMode           @default(UNDECIDED)
  // Relations
  createdBy              User                     @relation(fields: [createdById], references: [id])
  createdById            String
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  phases                 Phase[]
  assumptions            Assumption[]
  risks                  RiskRegisterEntry[]
  stageSummaries         EngagementStageSummary[]
  torRequirements        TorRequirement[]
  lineItems              LineItem[]
  validationReports      ValidationReport[]
  gapFixRuns             GapFixRun[]
  embeddingChunks        EmbeddingChunk[]
  deliveryPhases         DeliveryPhase[]

  @@index([accountId])
}

enum RfpSource {
  DIRECT_INVITE
  PUBLIC_TENDER
  REFERRAL
  PARTNER
  REPEAT_CLIENT
  INBOUND
  OTHER
}

enum EngagementOutcome {
  WON
  LOST
  NO_DECISION
  WITHDRAWN
  PARTIAL_WIN
  DEFERRED
  NOT_SUBMITTED
}

enum LossReason {
  PRICE_TOO_HIGH
  SCOPE_MISMATCH
  COMPETITOR_PREFERRED
  TIMELINE_MISMATCH
  BUDGET_CUT
  RELATIONSHIP
  TECHNICAL_FIT
  NO_DECISION_MADE
  OTHER
}

enum WorkflowPath {
  NO_RESPONSE
  HAS_RESPONSE
}

enum TechStack {
  DRUPAL
  DRUPAL_NEXTJS
  WORDPRESS
  WORDPRESS_NEXTJS
  NEXTJS
  REACT
  OTHER
}

enum EngagementType {
  NEW_BUILD
  MIGRATION
  REDESIGN
  ENHANCEMENT
  DISCOVERY
}

enum EngagementStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

model Phase {
  id             String          @id @default(cuid())
  engagement     Engagement      @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId   String
  phaseNumber    String
  status         PhaseStatus     @default(PENDING)
  startedAt      DateTime?
  completedAt    DateTime?
  agentSessionId String?
  artefacts      PhaseArtefact[]

  @@unique([engagementId, phaseNumber])
}

enum PhaseStatus {
  PENDING
  RUNNING
  REVIEW
  APPROVED
  SKIPPED
  FAILED
}

model PhaseArtefact {
  id              String        @id @default(cuid())
  phase           Phase         @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  phaseId         String
  artefactType    ArtefactType
  version         Int           @default(1)
  label           String?
  contentMd       String?
  fileUrl         String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  deliveryPhaseId String?
  deliveryPhase   DeliveryPhase? @relation(fields: [deliveryPhaseId], references: [id], onDelete: SetNull)

  @@unique([phaseId, artefactType, version])
}

model DeliveryPhase {
  id                  String                  @id @default(cuid())
  engagementId        String
  ordinal             Int
  name                String
  summary             String                  @db.Text
  scopeBullets        Json
  targetDurationWeeks Int?
  sourceType          DeliveryPhaseSourceType @default(AI_INFERRED)
  status              DeliveryPhaseStatus     @default(DRAFT)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  engagement          Engagement              @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  lineItems           LineItem[]
  phaseArtefacts      PhaseArtefact[]

  @@unique([engagementId, ordinal])
  @@index([engagementId])
}

enum ArtefactType {
  TOR_ASSESSMENT
  QUESTIONS
  ESTIMATE
  PROPOSAL
  GAP_ANALYSIS
  RESEARCH
  REVIEW
  RESPONSE_ANALYSIS
  ESTIMATE_STATE
  ANNEXURE
  PREREQUISITES
  RESPONSE_FORMAT
  LEGACY_ACCESS_CHECKLIST
  PROJECT_PLAN
  DELIVERY_PHASES_INFERENCE
}

enum EstimationMode {
  BIG_BANG
  PHASED
  UNDECIDED
}

enum DeliveryPhaseSourceType {
  AI_INFERRED
  USER_EDITED
  USER_DEFINED
}

enum DeliveryPhaseStatus {
  DRAFT
  CONFIRMED
}

model Assumption {
  id                 String           @id @default(cuid())
  engagement         Engagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId       String
  sourcePhaseId      String
  text               String
  torReference       String?
  impactIfWrong      String
  status             AssumptionStatus @default(ACTIVE)
  confirmedById      String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  torRequirementRefs TorRequirement[] @relation("AssumptionToTorRequirement")
  lineItemRefs       LineItem[]       @relation("AssumptionToLineItem")
}

enum AssumptionStatus {
  ACTIVE
  SUPERSEDED
  CONFIRMED
  REJECTED
}

model RiskRegisterEntry {
  id                String     @id @default(cuid())
  engagement        Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId      String
  task              String
  tab               String
  conf              Int
  risk              String
  openQuestion      String
  recommendedAction String
  hoursAtRisk       Float
  createdAt         DateTime   @default(now())
}

model Benchmark {
  id                 String    @id @default(cuid())
  techStack          TechStack
  category           String
  taskType           String
  lowHours           Float
  highHours          Float
  tier               String?
  notes              String?
  sourceEngagementId String?
  isActive           Boolean   @default(true)
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([techStack, category])
}

model PhaseExecution {
  id               String    @id @default(cuid())
  phaseId          String
  engagementId     String
  userId           String
  phaseNumber      String
  startedAt        DateTime
  completedAt      DateTime?
  durationMs       Int?
  inputTokens      Int       @default(0)
  outputTokens     Int       @default(0)
  totalTokens      Int       @default(0)
  modelId          String?
  estimatedCostUsd Float?
  apiCallCount     Int       @default(0)
  turnCount        Int       @default(0)
  status           String // "COMPLETED", "FAILED", "TIMEOUT"
  createdAt        DateTime  @default(now())

  @@index([engagementId])
  @@index([userId])
}

model ImportJob {
  id                   String       @id @default(cuid())
  userId               String
  source               String // "ZIP_IMPORT"
  sourcePath           String // original ZIP filename
  status               ImportStatus @default(PENDING)
  totalFiles           Int          @default(0)
  processedFiles       Int          @default(0)
  confirmedFiles       Int          @default(0)
  skippedFiles         Int          @default(0)
  zipHash              String? // SHA-256 hash of ZIP for dedup
  autoConfirmThreshold Float? // e.g. 0.8 — auto-confirm items above this confidence
  batchId              String? // links multiple ZIPs uploaded together
  errorMessage         String?
  estimatedCostUsd     Float?
  actualCostUsd        Float?
  inputTokensUsed      Int          @default(0)
  outputTokensUsed     Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  items                ImportItem[]

  @@index([batchId])
}

model ImportItem {
  id                         String           @id @default(cuid())
  importJob                  ImportJob        @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  importJobId                String
  folderName                 String // subfolder name from ZIP (= engagement grouping)
  files                      Json // [{ name, type: "TOR"|"ESTIMATE"|"PROPOSAL"|"FINANCIAL"|"OTHER", sizeBytes, isPrimary }]
  primaryFileName            String?
  // AI-inferred metadata (editable by admin before confirm)
  inferredClient             String?
  inferredIndustry           String?
  inferredTechStack          String?
  inferredEngagementType     String?
  inferredProjectName        String?
  inferredSubmissionDeadline DateTime?
  inferredIssueDate          DateTime?
  inferredDealValue          Float?
  inferredFinancialValue     Float?
  confidence                 Json? // { clientName: 0.9, ... }
  extractedTextPreview       String? // first 500 chars for admin review
  processedFiles             Json? // [{ name, type, extractedText: boolean, artefactCreated: boolean, isSubmission: boolean }]
  // Resolution
  matchedAccountId           String? // auto-matched or admin-selected
  status                     ImportItemStatus @default(PENDING_REVIEW)
  engagementId               String? // set after confirm creates the Engagement
  reviewedAt                 DateTime?
  reviewedBy                 String?
  errorMessage               String?
  createdAt                  DateTime         @default(now())

  @@index([importJobId])
}

enum ImportStatus {
  PENDING
  PROCESSING
  PAUSED
  REVIEW
  COMPLETED
  FAILED
}

enum ImportItemStatus {
  PENDING_REVIEW
  CONFIRMED
  SKIPPED
  FAILED
}

model EngagementStageSummary {
  id            String     @id @default(cuid())
  engagement    Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId  String
  phaseNumber   String // "0", "1", "1A", "2", "5"
  summary       String // AI-generated summary
  documentCount Int        @default(0)
  keyFindings   Json? // { requirements: [...], risks: [...], decisions: [...] }
  generatedAt   DateTime   @default(now())

  @@unique([engagementId, phaseNumber])
  @@index([engagementId])
}

model ClassificationCorrection {
  id                 String   @id @default(cuid())
  fileName           String
  originalType       String
  correctedType      String
  originalConfidence Float
  textSnippet        String?
  correctedBy        String
  createdAt          DateTime @default(now())

  @@index([correctedType])
}

model PromptConfig {
  id        String          @id @default(cuid())
  key       String          @unique // e.g., "system-base", "phase-0", "phase-1a-estimate", "carl-rules"
  label     String // Human-readable name
  category  PromptCategory
  content   String // The prompt/benchmark/template text
  isDefault Boolean         @default(true) // true if unchanged from code default
  updatedBy String?
  updatedAt DateTime        @updatedAt
  createdAt DateTime        @default(now())
  versions  PromptVersion[]
}

enum PromptCategory {
  SYSTEM_BASE
  PHASE_PROMPT
  CARL_RULES
  BENCHMARK
  TEMPLATE
}

model PromptVersion {
  id             String       @id @default(cuid())
  promptConfig   PromptConfig @relation(fields: [promptConfigId], references: [id], onDelete: Cascade)
  promptConfigId String
  content        String // Snapshot of content at this version
  changedBy      String // User ID
  changeNote     String? // Optional description of change
  createdAt      DateTime     @default(now())

  @@index([promptConfigId])
}

model PromptOverride {
  id          String   @id @default(cuid())
  phaseNumber String
  promptType  String // "SYSTEM" or "USER"
  content     String
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdBy   String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([phaseNumber, promptType, isActive])
}

// ─── Accuracy / alignment models (M1 foundation) ────────────────────────────

/// Structured record of every requirement extracted from the TOR during Phase 1.
/// Downstream validators query these to compute coverage, gap, and orphan metrics.
model TorRequirement {
  id                  String     @id @default(cuid())
  engagement          Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId        String
  clauseRef           String // as written in TOR, e.g. "3.2.1" or "Section 4.1"
  normalizedClauseRef String // lowercased, whitespace-stripped for fuzzy matching
  title               String
  description         String
  domain              String // content_arch | integration | migration | frontend | devops | seo | a11y | perf | security | other
  clarityRating       String // CLEAR | NEEDS_CLARIFICATION | AMBIGUOUS | MISSING_DETAIL
  sourcePhaseId       String?
  createdAt           DateTime   @default(now())

  lineItems   LineItem[]   @relation("LineItemToTorRequirement")
  assumptions Assumption[] @relation("AssumptionToTorRequirement")

  @@index([engagementId])
  @@index([engagementId, normalizedClauseRef])
}

/// Structured record per estimate line item. Written alongside the XLSX by
/// Phase 1A / Phase 3 / XLSX import, so downstream validators don't have to
/// regex-parse markdown.
model LineItem {
  id                  String     @id @default(cuid())
  engagement          Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId        String
  tab                 String // BACKEND | FRONTEND | FIXED_COST | DESIGN | AI
  task                String
  description         String
  hours               Float
  conf                Int // 1-6
  lowHrs              Float // = hours
  highHrs             Float // = hours * (1 + conf buffer %); see CARL rule 14
  benchmarkRef        String?
  integrationTier     String? // T1 | T2 | T3 when the line item represents an integration
  orphanJustification String? // populated only when no TorRequirement is linked
  sourcePhaseId       String?
  deliveryPhaseId     String?
  createdAt           DateTime   @default(now())

  torRefs        TorRequirement[] @relation("LineItemToTorRequirement")
  assumptionRefs Assumption[]     @relation("AssumptionToLineItem")
  deliveryPhase  DeliveryPhase?   @relation(fields: [deliveryPhaseId], references: [id], onDelete: SetNull)

  @@index([engagementId, tab])
  @@index([deliveryPhaseId])
}

/// One row per validator run — aggregated accuracy signal surfaced in the UI.
model ValidationReport {
  id                    String     @id @default(cuid())
  engagement            Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId          String
  phaseNumber           String
  ranAt                 DateTime   @default(now())
  overallStatus         String // PASS | WARN | FAIL
  accuracyScore         Float // 0..1
  gapCount              Int        @default(0)
  orphanCount           Int        @default(0)
  confFormulaViolations Int        @default(0)
  noBenchmarkCount      Int        @default(0)
  details               Json // keyed per-validator output

  @@index([engagementId, phaseNumber])
  @@index([engagementId, ranAt])
}

/// Observability record for every Anthropic API call issued from the backend.
/// Used by the schema-retry wrapper (M6) and the /admin/ai-health page.
model AiCallLog {
  id                String   @id @default(cuid())
  engagementId      String?
  phase             String?
  model             String
  promptHash        String?
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  durationMs        Int      @default(0)
  retryCount        Int      @default(0)
  validationOutcome String // PASS | FAIL | RETRIED_OK
  errorMessage      String?
  createdAt         DateTime @default(now())

  @@index([engagementId])
  @@index([createdAt])
}

// ─── Scoped RAG chatbot models ──────────────────────────────────────────────

/// Vector-indexed chunks of engagement / global content (artefacts, requirements,
/// line items, assumptions, risks, benchmarks, accounts, engagement metadata).
/// engagementId is null for admin/global chunks (benchmarks, cross-engagement
/// aggregates). The chat retrieval filter hard-scopes by engagementId server-side.
model EmbeddingChunk {
  id           String                      @id @default(cuid())
  engagement   Engagement?                 @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId String?
  sourceType   String // ARTEFACT | REQUIREMENT | LINE_ITEM | ASSUMPTION | RISK | BENCHMARK | ACCOUNT | ENGAGEMENT_META
  sourceId     String // id of the source row
  chunkIndex   Int                         @default(0) // for multi-chunk artefacts
  content      String                      @db.Text
  embedding    Unsupported("vector(1536)") // OpenAI text-embedding-3-small dim
  tokens       Int                         @default(0)
  metadata     Json? // source-specific extras (clauseRef, taskName, etc.)
  createdAt    DateTime                    @default(now())

  @@index([engagementId])
  @@index([sourceType])
  @@index([engagementId, sourceType])
}

/// Audit trail for every chat turn. Retrieved chunk IDs are recorded so we can
/// later verify that answers only came from in-scope context.
model ChatAuditLog {
  id            String   @id @default(cuid())
  userId        String
  scope         String // ENGAGEMENT | ADMIN
  engagementId  String?
  question      String   @db.Text
  chunkIds      String[] @default([])
  answerPreview String   @db.Text
  tokensIn      Int      @default(0)
  tokensOut     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([engagementId, createdAt])
}

/// Tracks one user-triggered "Fix Gaps" pass against an engagement's estimate.
/// Each run snapshots gap metrics before/after so the UI can show delta scores.
model GapFixRun {
  id           String     @id @default(cuid())
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId String
  status       String     @default("QUEUED") // QUEUED | RUNNING | DONE | FAILED
  jobId        String?    // BullMQ job ID for SSE matching
  gapsBefore   Json       // { gapCount, orphanCount, confViolations, noBenchmarkCount, phaseNumber }
  scoresBefore Json?      // { phaseNumber: string, accuracyScore: number }[]
  scoresAfter  Json?      // { phaseNumber: string, accuracyScore: number }[]
  errorMessage String?    @db.Text
  createdAt    DateTime   @default(now())
  completedAt  DateTime?

  @@index([engagementId, createdAt])
}

/// Web-researched ecosystem summary and bootstrapped benchmark table for
/// engagements with a non-enum (OTHER) tech stack. Populated once per
/// engagement by the tech-stack-research worker before Phase 1A estimate.
model TechStackResearch {
  id                 String     @id @default(cuid())
  engagement         Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  engagementId       String     @unique
  stackDescription   String     @db.Text // echo of Engagement.techStackCustom at research time
  ecosystemSummary   String     @db.Text // markdown summary of frameworks, libs, hosting, community
  benchmarksMarkdown String     @db.Text // markdown benchmark table ingested into Phase 1A prompt
  sourcesJson        Json // array of { url, title, fetchedAt }
  provider           String? // e.g. "tavily"
  createdAt          DateTime   @default(now())
}
